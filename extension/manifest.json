{
  "manifest_version": 3,
  "name": "VideoWatch",
  "version": "1.0.0",
  "description": "One-click add the current site to your VideoWatch monitor.",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"]
}
